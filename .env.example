APP_NAME=Enterprise RAG Agent
APP_ENV=development
API_PREFIX=/api/v1
CHUNK_SIZE=500
CHUNK_OVERLAP=80
DEFAULT_TOP_K=3
DATABASE_PATH=data/app.db
VECTOR_STORE_PROVIDER=qdrant
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION=knowledge_chunks
MILVUS_URI=data/milvus.db
MILVUS_TOKEN=
MILVUS_COLLECTION=knowledge_chunks
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
VECTOR_SCORE_THRESHOLD=0.05
LLM_PROVIDER=extractive
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
QUERY_REWRITE_ENABLED=false
RERANKER_PROVIDER=heuristic
RERANKER_BASE_URL=
RERANKER_API_KEY=
RERANKER_MODEL=
AUTO_APPROVE_READ_ACTIONS=false
MCP_SERVERS_JSON=[]

CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
FEISHU_WEBHOOK_URL=
FEISHU_DRY_RUN=true
